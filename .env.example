# Server
PORT=8000
NODE_ENV=development
# Comma-separated list of allowed origins (no spaces after commas). Only one is sent per response.
# Example: https://imfbxd.com,https://www.imfbxd.com,https://imfbxd.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=imf_db

# ImageKit (used for all uploaded images so they keep working even if the backend sleeps)
# Get these from your ImageKit dashboard.
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=

# Auth (set a strong secret in production)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Initial admin (only used when no Admin user exists yet)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=12345678
ADMIN_NAME=Admin
